# Copy this to .env and fill in your values

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-32-chars-min

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=nexus_erp

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_CONNECT_URL=http://localhost:8083
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-5-20251101

# ── NAM (Neural Addressed Memory) ──────────────────────────────────────────────
# For Docker Compose these are set automatically to the container names.
# For local dev, run nam-query and nam-encoder separately.
NAM_QUERY_URL=http://localhost:8010
NAM_ENCODER_URL=http://localhost:8011
NAM_QUERY_USERNAME=admin
NAM_QUERY_PASSWORD=password
# KV (Couchbase) host — only required if NAM is backed by a live Couchbase node
NAM_KV_HOST=
NAM_KV_PORT=11210

# ── NNLM (Neural Network Language Model) ───────────────────────────────────────
# For Docker Compose these are set automatically to the container names.
# For local dev, run nnlm-encoder and nnlm-decoder separately.
NNLM_ENCODER_URL=http://localhost:8001
NNLM_DECODER_URL=http://localhost:8002
ENABLE_NNLM=true
# NNLM decoder uses OpenAI for final synthesis (optional — falls back to rule-based)
OPENAI_API_KEY=
DECODER_MODEL=gpt-4o-mini

# ── Docker Compose source paths (for building NAM/NNLM from local source) ──────
# These are relative to docker-compose.yml (i.e. the nexus-erp project root)
NAM_SRC=../nam-0.0.1
NNLM_SRC=../nnlm

# ── Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ──
FERNET_KEY=your-fernet-key-here

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_CDC=true
ENABLE_AGENT=true
HUMAN_IN_LOOP_REQUIRED=true

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,http://localhost:3000
